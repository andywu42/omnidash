{
  "name": "rest-express",
  "version": "1.1.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "kill-port": "bash scripts/kill-server.sh",
    "dev": "npm run kill-port && PORT=3000 NODE_ENV=development scripts/dev.sh tsx server/index.ts",
    "dev:local": "npm run kill-port && OMNIDASH_BUS_MODE=local KAFKA_BOOTSTRAP_SERVERS=localhost:19092 PORT=3000 NODE_ENV=development scripts/dev.sh tsx server/index.ts",
    "dev:cloud": "npm run kill-port && OMNIDASH_BUS_MODE=cloud KAFKA_BOOTSTRAP_SERVERS=localhost:29092 PORT=3000 NODE_ENV=development scripts/dev.sh tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "npm run kill-port && PORT=3000 NODE_ENV=production scripts/dev.sh node dist/index.js",
    "start:local": "npm run kill-port && OMNIDASH_BUS_MODE=local KAFKA_BOOTSTRAP_SERVERS=localhost:19092 PORT=3000 NODE_ENV=production scripts/dev.sh node dist/index.js",
    "start:cloud": "npm run kill-port && OMNIDASH_BUS_MODE=cloud KAFKA_BOOTSTRAP_SERVERS=localhost:29092 PORT=3000 NODE_ENV=production scripts/dev.sh node dist/index.js",
    "check": "tsc",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "lint:topics": "bash scripts/lint-no-hardcoded-topics.sh",
    "test": "vitest",
    "test:ci": "vitest run --no-coverage --reporter=verbose",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:snapshots": "playwright test",
    "test:snapshots:update": "playwright test --update-snapshots",
    "test:snapshots:ui": "playwright test --ui",
    "test:snapshots:debug": "playwright test --debug",
    "test:snapshots:report": "playwright show-report",
    "test:smoke": "tsx scripts/dashboard-smoke-test.ts",
    "check:bus-parity": "tsx scripts/check-bus-parity.ts",
    "db:push": "echo 'ERROR: db:push is disabled. SQL migrations are canonical. Use npm run db:migrate instead. See CLAUDE.md for details.' && exit 1",
    "db:migrate": "tsx scripts/run-migrations.ts",
    "db:check-parity": "tsx scripts/check-migration-parity.ts",
    "db:check-coupling": "tsx scripts/check-migration-required.ts",
    "db:test:setup": "tsx scripts/setup-test-db.ts",
    "seed-events": "tsx scripts/seed-events.ts",
    "seed-events:continuous": "tsx scripts/seed-events.ts --continuous",
    "seed-effectiveness": "tsx scripts/seed-effectiveness.ts",
    "seed-intents": "tsx scripts/seed-intent-events.ts",
    "seed-intents:continuous": "tsx scripts/seed-intent-events.ts --continuous",
    "seed-demo-patterns": "tsx scripts/seed-demo-patterns.ts seed",
    "cleanup-demo-patterns": "tsx scripts/seed-demo-patterns.ts cleanup",
    "status-demo-patterns": "tsx scripts/seed-demo-patterns.ts status",
    "check-topics": "tsx scripts/check-kafka-topics.ts",
    "record-events": "tsx scripts/record-events.ts",
    "record-events:5min": "tsx scripts/record-events.ts --duration 300",
    "test:auth-smoke": "bash scripts/auth-smoke-test.sh",
    "clean:screenshots": "bash scripts/clean-screenshots.sh",
    "postinstall": "patch-package",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@jridgewell/trace-mapping": "^0.3.25",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-accordion": "^1.2.4",
    "@radix-ui/react-alert-dialog": "^1.1.7",
